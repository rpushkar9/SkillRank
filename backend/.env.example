APP_NAME=SkillRank API
APP_ENV=dev
APP_DEBUG=true
API_V1_PREFIX=/api/v1

QDRANT_URL=
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=skills
QDRANT_API_KEY=

EMBED_MODEL=all-MiniLM-L6-v2
EMBED_DIM=384

SKILLS_JSONL_PATH=../skills_scraper/data/skills_raw.jsonl
DEFAULT_TOP_K=5
MAX_TOP_K=20
QDRANT_TOP_N=50
SKIP_STARTUP_CHECKS=false
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
